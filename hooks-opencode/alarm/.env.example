# Telegram bot settings for the OpenCode alarm hook.
# Never commit real tokens.
OPENCODE_TELEGRAM_BOT_TOKEN=123456:replace-me
OPENCODE_TELEGRAM_CHAT_ID=123456789

# Optional: Telegram forum topic/thread ID.
# OPENCODE_TELEGRAM_TOPIC_ID=42

# Optional: include subagent session lifecycle notifications.
# OPENCODE_TELEGRAM_NOTIFY_SUBAGENTS=false
